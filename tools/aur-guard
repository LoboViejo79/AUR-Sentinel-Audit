#!/usr/bin/env bash
set -euo pipefail
PKG="${1:-}"
HELPER="${2:-yay}"
DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$DIR/.." && pwd)"
SCANNER="$DIR/aur_guard_preinstall.py"

gui_msg() {
  local title="$1"; local msg="$2"; local type="${3:-info}"
  if command -v kdialog >/dev/null 2>&1; then
    case "$type" in error) kdialog --title "$title" --error "$msg";; warning) kdialog --title "$title" --sorry "$msg";; yesno) kdialog --title "$title" --yesno "$msg";; *) kdialog --title "$title" --msgbox "$msg";; esac
  elif command -v zenity >/dev/null 2>&1; then
    case "$type" in error) zenity --title="$title" --error --text="$msg";; warning) zenity --title="$title" --warning --text="$msg";; yesno) zenity --title="$title" --question --text="$msg";; *) zenity --title="$title" --info --text="$msg";; esac
  else
    echo "==== $title ===="; echo "$msg"
    if [[ "$type" == "yesno" ]]; then read -r -p "Continuar? [s/N]: " R; [[ "$R" =~ ^[sS]$ ]]; fi
  fi
}
popup_15() {
  local title="$1"; local msg="$2"; local type="${3:-info}"
  if command -v kdialog >/dev/null 2>&1; then kdialog --title "$title" --passivepopup "$msg" 15 || true
  elif command -v zenity >/dev/null 2>&1; then zenity --title="$title" --info --text="$msg" --timeout=15 || true
  elif command -v notify-send >/dev/null 2>&1; then notify-send -t 15000 "$title" "$msg"; fi
}
if [[ -z "$PKG" ]]; then gui_msg "AUR Sentinel Guard" "Uso: aur-guard <paquete> [yay|paru]" "error"; exit 1; fi
REAL_HELPER="$(type -P "$HELPER" || true)"
if [[ -z "$REAL_HELPER" ]]; then gui_msg "AUR Sentinel Guard" "No se encontró helper AUR: $HELPER" "error"; exit 2; fi

gui_msg "AUR Sentinel Guard" "Revisión previa obligatoria antes de instalar:

Paquete: $PKG
Helper: $HELPER

Controles:
1) Listas reportadas.
2) Snapshot completo AUR.
3) PKGBUILD y .install.
4) Firmas atomic-lockfile/js-digest/eBPF/rootkit.
5) Confirmación manual." "info"

cd "$ROOT"
popup_15 "AUR Sentinel Guard" "Analizando $PKG antes de instalar..." "info"
set +e
SCAN_OUTPUT="$(python "$SCANNER" "$PKG" --cache "data/aur_malware_package_list.txt" 2>&1)"
SCAN_CODE=$?
set -e
if [[ "$SCAN_CODE" -ne 0 ]]; then
  echo "$SCAN_OUTPUT"
  popup_15 "AUR Sentinel Guard - BLOQUEADO" "❌ $PKG no pasó revisión. Instalación bloqueada." "error"
  gui_msg "AUR Sentinel Guard - BLOQUEADO" "❌ INSTALACIÓN BLOQUEADA

Paquete: $PKG

$SCAN_OUTPUT" "error"
  exit "$SCAN_CODE"
fi
echo "$SCAN_OUTPUT"
popup_15 "AUR Sentinel Guard - APROBADO" "✅ $PKG pasó controles. Esperando confirmación." "info"
if gui_msg "AUR Sentinel Guard - Confirmar instalación" "✅ CONTROLES APROBADOS

Paquete: $PKG

$SCAN_OUTPUT

¿Continuar con $HELPER?" "yesno"; then
  exec "$REAL_HELPER" -S "$PKG"
else
  echo "Instalación cancelada."
  exit 0
fi
